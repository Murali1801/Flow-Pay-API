# Webhook auth for MacroDroid / Tasker
WEBHOOK_BEARER_TOKEN=my_super_secret_college_key

# Firestore (Admin SDK): download JSON from Firebase Console → Project settings → Service accounts
FIREBASE_CREDENTIALS_PATH=./firebase-adminsdk.json

# Comma-separated Firebase Auth UIDs that get platform admin (all merchants + orders)
FLOWPAY_ADMIN_UIDS=
